<UserControl x:Class="SteamLamp.FriendsListControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:SteamLamp"
             mc:Ignorable="d" 
             d:DesignHeight="500" d:DesignWidth="800">

    <UserControl.Resources>
        <Style TargetType="ContextMenu">
            <Setter Property="Background" Value="#2a2e33"/>
            <Setter Property="BorderBrush" Value="#3d4450"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="0"/>
            <Style.Resources>
                <Style TargetType="MenuItem">
                    <Setter Property="Foreground" Value="#c6d4df"/>
                    <Setter Property="Padding" Value="10,8"/>
                    <Setter Property="FontSize" Value="12"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="MenuItem">
                                <Border x:Name="Bg" Background="{TemplateBinding Background}" BorderThickness="0">
                                    <ContentPresenter ContentSource="Header" Margin="{TemplateBinding Padding}"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Bg" Property="Background" Value="#3d4450"/>
                                        <Setter Property="Foreground" Value="White"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </Style.Resources>
        </Style>

        <Style x:Key="SteamOptionButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#54a5d4"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="2">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#3d4450"/>
                                <Setter Property="Foreground" Value="#66c0f4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Border Background="#1b2838" BorderBrush="#2a2e33" BorderThickness="1" CornerRadius="4">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="240"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="#171a21" BorderBrush="#2a2e33" BorderThickness="0,0,1,0">
                <StackPanel Margin="15">

                    <Grid Margin="0,0,0,30">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="45"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Border Width="40" Height="40" Background="#3d4450" BorderBrush="#66c0f4" BorderThickness="2" CornerRadius="2">
                            <Grid>
                                <TextBlock Text="AVA" Foreground="#66c0f4" FontSize="10" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                <Image x:Name="UserSelfAvatar" Stretch="UniformToFill" RenderOptions.BitmapScalingMode="HighQuality"/>
                            </Grid>
                        </Border>

                        <StackPanel Grid.Column="1" Margin="12,0" VerticalAlignment="Center">
                            <TextBlock x:Name="FriendsNickName" Text="NickNAME" Foreground="White" FontWeight="Bold" FontSize="14"/>
                            <TextBlock Text="В сети" Foreground="#66c0f4" FontSize="11"/>
                        </StackPanel>
                    </Grid>

                    <TextBlock Text="ДРУЗЬЯ" Foreground="#54a5d4" FontSize="11" FontWeight="Bold" Margin="10,0,0,10"/>

                    <Button x:Name="BtnShowFriends" Content="Ваши друзья" 
                            HorizontalContentAlignment="Left" Background="#3d4450" Foreground="White" 
                            BorderThickness="0" Padding="15,10" Margin="0,0,0,4" Cursor="Hand" 
                            Click="BtnShowFriends_Click">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="3"/>
                            </Style>
                        </Button.Resources>
                    </Button>

                    <Button x:Name="BtnAddFriends" Content="Добавить в друзья" 
                            HorizontalContentAlignment="Left" Background="Transparent" Foreground="#898989" 
                            BorderThickness="0" Padding="15,10" Cursor="Hand" 
                            Click="OpenAddFriendTab_Click">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="3"/>
                            </Style>
                        </Button.Resources>
                    </Button>

                    <Separator Background="#2a2e33" Margin="0,20"/>

                    <Button Content="← НАЗАД К ПРОФИЛЮ" Click="BackToProfile_Click" 
                            Background="Transparent" Foreground="#676767" BorderThickness="0" 
                            FontSize="10" FontWeight="Bold" HorizontalAlignment="Left" Cursor="Hand"/>
                </StackPanel>
            </Border>

            <Grid Grid.Column="1" Margin="30,25">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock x:Name="TabTitle" Grid.Row="0" Text="ВСЕ ДРУЗЬЯ" 
                           Foreground="White" FontSize="24" FontWeight="Light" Margin="0,0,0,25"/>

                <Grid x:Name="SearchArea" Grid.Row="1" Visibility="Collapsed" Margin="0,0,0,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <Border Background="#212c3d" BorderBrush="#10161f" BorderThickness="1" CornerRadius="2">
                        <TextBox x:Name="FriendSearchBox" 
                                 Background="Transparent" 
                                 BorderThickness="0" 
                                 Foreground="White" 
                                 Padding="12,10" 
                                 CaretBrush="White"
                                 FontSize="13"
                                 Text="Введите никнейм друга для поиска"
                                 GotFocus="FriendSearchBox_GotFocus"/>
                    </Border>

                    <Button Grid.Column="1" Content="Найти" Width="100" Margin="12,0,0,0" 
                            Background="#67a013" Foreground="White" FontWeight="Bold" 
                            BorderThickness="0" Cursor="Hand" Click="SearchBtn_Click">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="2"/>
                            </Style>
                        </Button.Resources>
                    </Button>
                </Grid>

                <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
                    <StackPanel x:Name="FriendsContainer"/>
                </ScrollViewer>
            </Grid>
        </Grid>
    </Border>
</UserControl>