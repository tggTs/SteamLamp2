<Window x:Class="SteamLamp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:SteamLamp"
        Title="Steam Lamp" Height="650" Width="1100"
        WindowStyle="None" 
        AllowsTransparency="True" 
        Background="Transparent"
        ResizeMode="CanResizeWithGrip"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <local:PathToImageConverter x:Key="PathToImageConverter"/>

        <Style x:Key="WindowControlButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="Gray"/>
            <Setter Property="Width" Value="40"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="WindowChrome.IsHitTestVisibleInChrome" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#3e434a"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="CloseButtonStyle" TargetType="Button" BasedOn="{StaticResource WindowControlButtonStyle}">
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#e81123"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>     
            </Style.Triggers>  
        </Style>     
    
        <Style x:Key="SteamMenuButtonStyle" TargetType="Button">  
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="LightGray"/>
            <Setter Property="FontSize" Value="20"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid Background="Transparent">
                            <StackPanel>
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,0,0,2"/>
                                <Border x:Name="Underline" Height="2" Background="#66c0f4" Visibility="Collapsed"/>
                            </StackPanel>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="Tag" Value="Selected">
                                <Setter Property="Foreground" Value="#66c0f4"/>
                                <Setter TargetName="Underline" Property="Visibility" Value="Visible"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SearchTextBoxStyle" TargetType="TextBox">
            <Setter Property="Background" Value="#316282"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}" CornerRadius="3">
                            <ScrollViewer x:Name="PART_ContentHost"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="BuyButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="15,5"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Background">
                <Setter.Value>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                        <GradientStop Color="#75b022" Offset="0"/>
                        <GradientStop Color="#588a1b" Offset="1"/>
                    </LinearGradientBrush>
                </Setter.Value>
            </Setter>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="2">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#8ed629"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="NavArrowStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#66c0f4"/>
            <Setter Property="FontSize" Value="30"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="64" 
                      ResizeBorderThickness="8" 
                      CornerRadius="20" 
                      GlassFrameThickness="0" />
    </WindowChrome.WindowChrome>

    <Border Background="#1b2838" BorderBrush="#2a2e33" BorderThickness="1" ClipToBounds="True" CornerRadius="20">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="64"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="35"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="#2a2e33" MouseLeftButtonDown="Header_MouseDown" Panel.ZIndex="1">
                <Grid>
                    <StackPanel x:Name="MainMenuStack" Orientation="Vertical" VerticalAlignment="Center" Margin="15,0,15,0">
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                            <TextBlock Text="STEAMLAMP" Foreground="White" FontWeight="Bold" FontSize="11" VerticalAlignment="Center" Margin="0,0,15,0" Opacity="0.8"/>
                            <Button x:Name="BtnSupport" Content="Тех. поддержка" Visibility="Collapsed" Click="OpenSupport_Click"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <Button x:Name="BtnStore" Content="МАГАЗИН" Style="{StaticResource SteamMenuButtonStyle}" Margin="0,0,20,0" Click="OpenStore_Click"/>
                            <Button x:Name="BtnLibrary" Content="БИБЛИОТЕКА" Style="{StaticResource SteamMenuButtonStyle}" Margin="0,0,20,0" Click="OpenLibrary_Click"/>
                            <Button x:Name="BtnProfile" Content="ПРОФИЛЬ" Style="{StaticResource SteamMenuButtonStyle}" Margin="0,0,20,0" Click="OpenProfile_Click"/>
                        </StackPanel>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Top">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,10,0">
                            <Button x:Name="LoginButton" Content="Войти / Регистрация" Style="{StaticResource BuyButtonStyle}" Click="LoginButton_Click"/>
                            <Button x:Name="AccountMenuButton" Content="NickNAME ▼" Foreground="#919499" Background="Transparent" BorderThickness="0" Click="AccountMenuButton_Click" Visibility="Collapsed"/>
                        </StackPanel>
                        <Button Content="—" Click="MinimizeApp_Click" Style="{StaticResource WindowControlButtonStyle}"/>
                        <Button x:Name="MaximizeBtn" Content="⬜" Click="MaximizeApp_Click" Style="{StaticResource WindowControlButtonStyle}"/>
                        <Button Content="✕" Click="CloseApp_Click" Style="{StaticResource CloseButtonStyle}"/>
                    </StackPanel>
                </Grid>
            </Border>

            <Grid Grid.Row="1" Background="#1b2838">
                <ContentControl x:Name="MainContentFrame">
                    <Grid x:Name="DefaultStoreView">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel Margin="30,20">
                                <Grid Margin="0,0,0,20">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <Grid x:Name="SearchContainer">
                                        <TextBox x:Name="SearchBox" Style="{StaticResource SearchTextBoxStyle}" Width="300" HorizontalAlignment="Left" TextChanged="SearchBox_TextChanged" GotFocus="SearchBox_GotFocus"/>
                                        <Popup x:Name="SearchPopup" PlacementTarget="{Binding ElementName=SearchBox}" Placement="Bottom" AllowsTransparency="True" StaysOpen="False">
                                            <Border Background="#2a2e33" BorderBrush="#3d4450" BorderThickness="1" Width="300">
                                                <ListBox x:Name="SearchResultsList" Background="Transparent" BorderThickness="0" SelectionChanged="SearchResultsList_SelectionChanged">
                                                    <ListBox.ItemTemplate>
                                                        <DataTemplate>
                                                            <StackPanel Orientation="Horizontal" Margin="5">
                                                                <Image Source="{Binding ImagePath, Converter={StaticResource PathToImageConverter}}" Width="45" Height="30" Stretch="UniformToFill"/>
                                                                <TextBlock Text="{Binding Title}" Foreground="White" Margin="10,0,0,0" VerticalAlignment="Center"/>
                                                            </StackPanel>
                                                        </DataTemplate>
                                                    </ListBox.ItemTemplate>
                                                </ListBox>
                                            </Border>
                                        </Popup>
                                    </Grid>

                                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                        <Button x:Name="BtnCart" Content="🛒 КОРЗИНА" Click="OpenCart_Click" Background="#3d4450" Foreground="White" Padding="10,5" BorderThickness="0"/>
                                        <Border Background="#66c0f4" CornerRadius="2" Margin="5,0,0,0" Padding="5,2">
                                            <TextBlock x:Name="CartCountText" Text="0" Foreground="Black" FontWeight="Bold"/>
                                        </Border>
                                    </StackPanel>
                                </Grid>

                                <TextBlock Text="ПОПУЛЯРНОЕ" Foreground="White" FontSize="18" FontWeight="Bold" Margin="0,0,0,15"/>

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="50"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="50"/>
                                    </Grid.ColumnDefinitions>
                                    <Button Grid.Column="0" Content="‹" Style="{StaticResource NavArrowStyle}" Click="PrevPage_Click"/>

                                    <Border Grid.Column="1" Background="#16202d" Height="300" BorderBrush="#2a2e33" BorderThickness="1">
                                        <Grid x:Name="ShowcaseContent">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="2*"/>
                                                <ColumnDefinition Width="1*"/>
                                            </Grid.ColumnDefinitions>
                                            <Image Source="{Binding ImagePath, Converter={StaticResource PathToImageConverter}}" Stretch="UniformToFill" Margin="10"/>
                                            <StackPanel Grid.Column="1" Margin="10,20">
                                                <TextBlock x:Name="ShowcaseName" Text="GameName" Foreground="White" FontSize="22" FontWeight="Bold"/>
                                                <TextBlock x:Name="ShowcasePrice" Text="0 руб." Foreground="White" FontSize="15" FontWeight="Bold" Margin="0,40,0,10"/>
                                                <Button x:Name="ShowcaseBuyBtn" Content="В корзину" Style="{StaticResource BuyButtonStyle}" Click="AddToCart_Click" Width="200" HorizontalAlignment="Left"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>

                                    <Button Grid.Column="2" Content="›" Style="{StaticResource NavArrowStyle}" Click="NextPage_Click"/>
                                </Grid>

                                <ItemsControl x:Name="GamesListControl" Margin="0,20,0,0">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <UniformGrid Columns="3" />
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                </ItemsControl>
                            </StackPanel>
                        </ScrollViewer>
                    </Grid>
                </ContentControl>

                <Grid x:Name="GameDetailsOverlay" Visibility="Collapsed" Panel.ZIndex="100">
                    <Border Background="#CC000000" MouseLeftButtonDown="CloseOverlay_Click"/>
                    <Border Background="#1b2838" Width="800" Height="450" CornerRadius="10" BorderBrush="#66c0f4" BorderThickness="1" VerticalAlignment="Center" HorizontalAlignment="Center">
                        <Grid Margin="20">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="1.5*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Image Source="{Binding ImagePath, Converter={StaticResource PathToImageConverter}}" Stretch="UniformToFill"/>
                            <StackPanel Grid.Column="1" Margin="25,0,0,0">
                                <TextBlock x:Name="ModalGameTitle" Foreground="White" FontSize="26" FontWeight="Bold" TextWrapping="Wrap"/>
                                <TextBlock x:Name="ModalGameDesc" Foreground="#898989" Margin="0,20,0,0" TextWrapping="Wrap" Height="200" FontSize="14"/>
                                <TextBlock x:Name="ModalGamePrice" Foreground="White" FontSize="22" FontWeight="Bold" Margin="0,20,0,10"/>
                                <Button Content="В КОРЗИНУ" Click="AddToCart_Click" Style="{StaticResource BuyButtonStyle}"/>
                                <Button Content="ЗАКРЫТЬ" Click="CloseOverlay_Click" Margin="0,10,0,0" Background="Transparent" Foreground="Gray" BorderThickness="0"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                </Grid>
            </Grid>

            <Border Grid.Row="2" Background="#171a21">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="10,0">
                    <TextBlock Text="ЗАГРУЗКИ" Foreground="#66c0f4" FontSize="11"/>
                    <ProgressBar IsIndeterminate="True" Width="100" Height="4" Margin="10,0"/>
                </StackPanel>
            </Border>

            <Popup x:Name="AccountPopup" PlacementTarget="{Binding ElementName=AccountMenuButton}" StaysOpen="False" AllowsTransparency="True">
                <Border Background="#2a2e33" BorderBrush="#1b2838" BorderThickness="1" Width="180" CornerRadius="5">
                    <StackPanel Margin="10">
                        <TextBlock x:Name="UserBalanceText" Text="Баланс: 0.00 руб." Foreground="#66c0f4" FontSize="12" FontWeight="Bold"/>
                        <Button Content="Кошелек" Click="OpenWallet_Click" Background="Transparent" Foreground="White" BorderThickness="0" Margin="0,5"/>
                        <Button Content="Выйти" Click="Logout_Click" Foreground="#e81123" Background="Transparent" BorderThickness="0"/>
                    </StackPanel>
                </Border>
            </Popup>
        </Grid>
    </Border>
</Window>