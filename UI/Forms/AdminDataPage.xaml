<UserControl x:Class="SteamLamp.UI.Forms.AdminDataPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:SteamLamp.UI.Forms"
      mc:Ignorable="d" 
      d:DesignHeight="600" d:DesignWidth="900">

    <Grid Background="#1b2838">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*"/>
            <ColumnDefinition Width="1.2*"/>
        </Grid.ColumnDefinitions>

        <StackPanel Grid.Column="0" Margin="20">
            <TextBlock Text="База пользователей" Foreground="White" FontSize="22" Margin="0,0,0,15"/>
            <ListBox x:Name="UsersListBox" Background="#2a475e" Foreground="White" 
                     BorderThickness="0" Height="450" DisplayMemberPath="Nickname" 
                     SelectionChanged="UsersListBox_SelectionChanged">
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="Padding" Value="10"/>
                        <Setter Property="Margin" Value="0,2"/>
                    </Style>
                </ListBox.ItemContainerStyle>
            </ListBox>
        </StackPanel>

        <Border Grid.Column="1" Background="#16202d" Margin="10,20,20,20" CornerRadius="5">
            <Grid Margin="15">
                <StackPanel>
                    <TextBlock Text="ИНФОРМАЦИЯ" Foreground="#66c0f4" FontSize="14" FontWeight="Bold" Margin="0,0,0,5"/>
                    <TextBlock x:Name="SelectedUserText" Text="Выберите пользователя" Foreground="White" FontSize="24" FontWeight="Bold" Margin="0,0,0,20" TextTrimming="CharacterEllipsis"/>

                    <Button Content="Скачать JSON" Click="ExportJson_Click" 
                            Background="#3d4450" Foreground="White" Padding="15,8" Margin="0,0,0,10" Cursor="Hand" BorderThickness="0"/>

                    <Button Content="Удалить аккаунт" Click="DeleteUser_Click" 
                            Background="#a62d2d" Foreground="White" Padding="15,8" FontWeight="Bold" Cursor="Hand" BorderThickness="0">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#e81123"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>

                    <Separator Background="#2a475e" Margin="0,20"/>

                    <StackPanel x:Name="UserDetailsPanel" Visibility="Collapsed">
                        <TextBlock Text="ДАННЫЕ ПРОФИЛЯ" Foreground="#66c0f4" FontSize="12" Margin="0,0,0,10"/>

                        <UniformGrid Columns="2">
                            <TextBlock Text="ID:" Foreground="Gray" Margin="0,5"/>
                            <TextBlock x:Name="TxtUserId" Foreground="White" Margin="0,5"/>

                            <TextBlock Text="Роль:" Foreground="Gray" Margin="0,5"/>
                            <TextBlock x:Name="TxtUserRole" Foreground="White" Margin="0,5"/>

                            <TextBlock Text="Баланс:" Foreground="Gray" Margin="0,5"/>
                            <TextBlock x:Name="TxtUserBalance" Foreground="#75b022" FontWeight="Bold" Margin="0,5"/>
                        </UniformGrid>
                    </StackPanel>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>