<UserControl x:Class="SteamLamp.UI.Forms.AdminDataPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:SteamLamp.UI.Forms"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800">

    <Grid Background="#1b2838">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*"/>
            <ColumnDefinition Width="1*"/>
        </Grid.ColumnDefinitions>

        <StackPanel Grid.Column="0" Margin="20">
            <TextBlock Text="База пользователей" Foreground="White" FontSize="22" Margin="0,0,0,15"/>
            <ListBox x:Name="UsersListBox" Background="#2a475e" Foreground="White" BorderThickness="0" Height="400" DisplayMemberPath="Nickname" SelectionChanged="UsersListBox_SelectionChanged"/>
        </StackPanel>

        <Border Grid.Column="1" Background="#16202d" Margin="10,20,20,20" CornerRadius="5">
            <StackPanel Margin="15">
                <TextBlock Text="Инструменты" Foreground="#66c0f4" FontSize="18" FontWeight="Bold" Margin="0,0,0,20"/>

                <TextBlock Text="Выбранный аккаунт:" Foreground="Gray"/>
                <TextBlock x:Name="SelectedUserText" Text="Не выбран" Foreground="White" FontSize="16" Margin="0,5,0,20"/>

                <Button Content="Скачать данные (JSON)" Click="ExportJson_Click" 
                        Background="#66c0f4" Foreground="White" Padding="15,10" FontWeight="Bold">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="3"/>
                        </Style>
                    </Button.Resources>
                </Button>

                <TextBlock Text="* Данные включают историю покупок и баланс" 
                           Foreground="#4e5359" FontSize="11" TextWrapping="Wrap" Margin="0,15,0,0"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
