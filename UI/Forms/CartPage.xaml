<UserControl x:Class="SteamLamp.CartPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:SteamLamp"
             Background="#1b2838">
    <UserControl.Resources>
        <Style x:Key="BuyButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#67bc19"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Padding" Value="20,10"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="2">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#82d22a"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>
    <Grid Margin="40,20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="ВАША КОРЗИНА" Foreground="White" FontSize="24" FontWeight="Bold" Margin="0,0,0,20"/>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <ItemsControl x:Name="CartItemsControl">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Background="#16202d" Margin="0,0,0,10" Padding="15">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Border Background="#212c3d" Height="60" Width="100" CornerRadius="2" ClipToBounds="True">
                                    <Image Source="{Binding ImagePath}" Stretch="UniformToFill" RenderOptions.BitmapScalingMode="HighQuality"/>
                                </Border>

                                <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="15,0">
                                    <TextBlock Text="{Binding Title}" Foreground="White" FontSize="18" FontWeight="Bold"/>
                                    <Button Content="Удалить" Foreground="#a3a3a3" Background="Transparent" BorderThickness="0"  HorizontalAlignment="Left" Cursor="Hand" Click="RemoveItem_Click" Tag="{Binding}"/>
                                </StackPanel>

                                <TextBlock Grid.Column="2" Text="{Binding Price}" Foreground="White" FontWeight="Bold" FontSize="16" VerticalAlignment="Center"/>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <Border Grid.Row="2" Background="#16202d" Padding="20" Margin="0,20,0,0">
            <StackPanel>
                <Grid>
                    <TextBlock Text="Итоговая сумма:" Foreground="#898989" FontSize="16"/>
                    <TextBlock x:Name="TotalAmountText" Text="0 руб." Foreground="White" FontSize="18" FontWeight="Bold" HorizontalAlignment="Right"/>
                </Grid>
                <Button Content="Купить." HorizontalAlignment="Right" Margin="0,15,0,0" Width="300" Height="35" Style="{StaticResource BuyButtonStyle}" Click="Purchase_Click"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>