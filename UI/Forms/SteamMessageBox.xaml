<Window x:Class="SteamLamp.SteamMessageBox"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        SizeToContent="WidthAndHeight"
        WindowStartupLocation="CenterOwner"
        MinWidth="350" MaxWidth="450">

    <Border Background="#2a475e" BorderBrush="#66c0f4" BorderThickness="1" CornerRadius="2">
        <StackPanel Margin="20">
            <TextBlock x:Name="TxtTitle" Text="УВЕДОМЛЕНИЕ" Foreground="#66c0f4" FontSize="14" FontWeight="Bold" Margin="0,0,0,15"/>

            <TextBlock x:Name="TxtMessage" Text="Сообщение" Foreground="White" FontSize="13" TextWrapping="Wrap" Margin="0,0,0,25"/>

            <Button Content="OK" HorizontalAlignment="Right" Width="80" Height="28" 
                    Background="#212c3d" Foreground="White" BorderThickness="1" BorderBrush="#3d4450"
                    Cursor="Hand" Click="Ok_Click">
                <Button.Style>
                    <Style TargetType="Button">
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#3d4450"/>
                                <Setter Property="BorderBrush" Value="#66c0f4"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>
        </StackPanel>
    </Border>
</Window>