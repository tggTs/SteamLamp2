<UserControl x:Class="SteamLamp.EditProfileControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#1b2838">
    <UserControl.Resources>
        <Style x:Key="SteamTextBox" TargetType="TextBox">
            <Setter Property="Background" Value="#171a21"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#2a2e33"/>
            <Setter Property="Padding" Value="8"/>
            <Setter Property="CaretBrush" Value="White"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Grid>
                            <Border Background="{TemplateBinding Background}" 
                                    BorderBrush="{TemplateBinding BorderBrush}" 
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="2"/>

                            <ScrollViewer x:Name="PART_ContentHost" 
                                          Margin="8,0,8,0"
                                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>

                            <TextBlock Text="{TemplateBinding Tag}" 
                                       Foreground="#4f535b" 
                                       IsHitTestVisible="False"
                                       Margin="12,0,0,0"
                                       x:Name="Watermark"
                                       VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                       Visibility="Collapsed"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="Text" Value="">
                                <Setter TargetName="Watermark" Property="Visibility" Value="Visible"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="AvatarSelectionButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="8"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" BorderBrush="Transparent" BorderThickness="2" CornerRadius="4">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="#66c0f4"/>
                                <Setter TargetName="border" Property="Background" Value="#2a2e33"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Border x:Name="EditMainPanel" Background="#16202d" BorderBrush="#2a2e33" BorderThickness="1" Padding="30" VerticalAlignment="Top" Margin="0,40,0,0" HorizontalAlignment="Center">
            <StackPanel Width="450">
                <TextBlock Text="РЕДАКТИРОВАНИЕ ПРОФИЛЯ" Foreground="White" FontSize="18" FontWeight="Bold" Margin="0,0,0,25"/>

                <TextBlock Text="АВАТАР" Foreground="#898989" FontSize="11" FontWeight="Bold" Margin="0,0,0,10"/>
                <Grid Margin="0,0,0,5">
                    <Button x:Name="BtnOpenAvatarStore" Content="Выберите аватар" Width="150" Height="32" HorizontalAlignment="Left" 
                            Background="#3d4450" Foreground="White" BorderThickness="0" Click="BtnOpenAvatarStore_Click" Cursor="Hand"/>

                    <Border x:Name="CurrentAvatarPreviewBorder" Width="40" Height="40" HorizontalAlignment="Right" BorderBrush="#66c0f4" BorderThickness="1">
                        <Image x:Name="CurrentAvatarPreviewImage" Stretch="UniformToFill"/>
                    </Border>
                </Grid>
                <TextBlock Text="Выберите аватарку из 6 предложенных вариантов" Foreground="#4f535b" FontSize="10" Margin="0,0,0,20"/>

                <TextBlock Text="ИЗМЕНЕНИЕ НИКНЕЙМА" Foreground="#898989" FontSize="11" FontWeight="Bold" Margin="0,10,0,5"/>
                <TextBox x:Name="EditNickname" Style="{StaticResource SteamTextBox}" 
                         Tag="Введите новый никнейм" FontSize="14" TextChanged="Field_TextChanged" 
                         Height="35" VerticalContentAlignment="Center"/>

                <TextBlock Text="ОПИСАНИЕ" Foreground="#898989" FontSize="11" FontWeight="Bold" Margin="0,20,0,5"/>
                <TextBox x:Name="EditBio" Style="{StaticResource SteamTextBox}" 
                         Tag="Добавьте описание профиля" Height="120" 
                         TextWrapping="Wrap" AcceptsReturn="True" 
                         VerticalContentAlignment="Top" Padding="8,10,8,10"
                         TextChanged="Field_TextChanged"/>

                <Button x:Name="SaveBtn" Content="Сохранить изменения" Margin="0,30,0,0" Height="40" 
                        Background="#3d4450" Foreground="#898989" IsEnabled="False" BorderThickness="0" Click="SaveBtn_Click" Cursor="Hand">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="2"/>
                        </Style>
                    </Button.Resources>
                </Button>
            </StackPanel>
        </Border>

        <Border x:Name="AvatarPickerOverlay" Background="#1b2838" Visibility="Collapsed" Padding="30">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <TextBlock Text="ВЫБЕРИТЕ ПЕРСОНАЖА" Foreground="White" FontSize="20" FontWeight="Bold" Margin="0,0,0,5" HorizontalAlignment="Center"/>
                <TextBlock Text="Ваш выбор будет виден всем пользователям SteamLamp" Foreground="#898989" FontSize="12" Margin="0,0,0,30" HorizontalAlignment="Center"/>

                <UniformGrid Columns="3" Width="360">
                    <Button Tag="ava1.png" Click="AvatarSelect_Click" Style="{StaticResource AvatarSelectionButtonStyle}">
                        <Image Source="pack://application:,,,/Assets/ava1.png" Width="100" Height="100" Stretch="UniformToFill"/>
                    </Button>
                    <Button Tag="ava2.png" Click="AvatarSelect_Click" Style="{StaticResource AvatarSelectionButtonStyle}">
                        <Image Source="pack://application:,,,/Assets/ava2.png" Width="100" Height="100" Stretch="UniformToFill"/>
                    </Button>
                    <Button Tag="ava3.png" Click="AvatarSelect_Click" Style="{StaticResource AvatarSelectionButtonStyle}">
                        <Image Source="pack://application:,,,/Assets/ava3.png" Width="100" Height="100" Stretch="UniformToFill"/>
                    </Button>
                    <Button Tag="ava4.png" Click="AvatarSelect_Click" Style="{StaticResource AvatarSelectionButtonStyle}">
                        <Image Source="pack://application:,,,/Assets/ava4.png" Width="100" Height="100" Stretch="UniformToFill"/>
                    </Button>
                    <Button Tag="ava5.png" Click="AvatarSelect_Click" Style="{StaticResource AvatarSelectionButtonStyle}">
                        <Image Source="pack://application:,,,/Assets/ava5.png" Width="100" Height="100" Stretch="UniformToFill"/>
                    </Button>
                    <Button Tag="ava6.png" Click="AvatarSelect_Click" Style="{StaticResource AvatarSelectionButtonStyle}">
                        <Image Source="pack://application:,,,/Assets/ava6.png" Width="100" Height="100" Stretch="UniformToFill"/>
                    </Button>
                </UniformGrid>

                <Button Content="ОТМЕНА" Margin="0,40,0,0" Width="120" Height="35" Background="#3d4450" Foreground="White" BorderThickness="0" Click="CloseAvatarPicker_Click" Cursor="Hand"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>